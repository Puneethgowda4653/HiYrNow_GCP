{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.json",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(png|jpg|jpeg|svg|gif|webp|avif|ico)"
        ]
      }
    },
    {
      "name": "fonts",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-auth",
      "urls": [
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/login",
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/logout",
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/register",
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/session",
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/auth/**",
        "/api/login",
        "/api/logout",
        "/api/register",
        "/api/session",
        "/api/auth/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 0,
        "maxAge": "0s",
        "timeout": "10s"
      }
    },
    {
      "name": "api-dynamic",
      "urls": [
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/**",
        "/api/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1h",
        "timeout": "10s"
      }
    },
    {
      "name": "api-jobs",
      "urls": [
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/jobs/**",
        "/api/jobs/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "30m",
        "timeout": "5s"
      }
    },
    {
      "name": "api-profile",
      "urls": [
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/users/**",
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/profile/**",
        "/api/users/**",
        "/api/profile/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "5m",
        "timeout": "5s"
      }
    },
    {
      "name": "api-static",
      "urls": [
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/categories/**",
        "https://hiyrnow-v1-721026586154.europe-west1.run.app/api/locations/**",
        "/api/categories/**",
        "/api/locations/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 20,
        "maxAge": "1d"
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/*.*",
    "!/**/*__*",
    "!/**/*__*/**"
  ],
  "navigationRequestStrategy": "freshness"
}
